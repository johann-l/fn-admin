{
  "name": "major-proj",
  "version": "1.0.6",
  "description": "Admin app for fleetNow",
  "main": "main.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development electron .",
    "build": "react-scripts build",
    "dist": "electron-builder"
  },
  "author": "Johann, Gladlin, Ashwin, Ayman",
  "license": "ISC",
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^35.1.4",
    "electron-builder": "^26.0.12",
    "electron-packager": "^17.1.2"
  },
  "dependencies": {
    "electron-updater": "^6.6.2"
  },
  "build": {
    "appId": "com.fleetnow.adminapp",
    "productName": "FleetNow Admin",
    "files": [
      "./fn-admin/build/**/*",
      "main.js",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "publish": {
      "provider": "github",
      "owner": "johann-l",
      "repo": "fn-admin"
    }
  }
}
